{
  "name": "tab",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && mkdir -p dist && cd src && zip -r ../dist/wildtab.zip wildtab.js wildtab",
    "dev": "node scripts/dev-sync.cjs",
    "check": "node scripts/check-js.cjs && eslint \"src/**/*.js\" --quiet",
    "lint": "eslint \"src/**/*.js\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "chokidar": "^5.0.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0"
  }
}
